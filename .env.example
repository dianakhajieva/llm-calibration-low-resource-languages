# Copy this file to ".env" and fill in only the keys you actually use.
# NEVER commit the real .env file (it is already listed in .gitignore).

# OpenAI (for GPT models): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Anthropic Claude (optional): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Hugging Face token (needed to download some gated models like Llama):
# https://huggingface.co/settings/tokens
HF_TOKEN=
